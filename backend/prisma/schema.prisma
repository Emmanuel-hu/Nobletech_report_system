  curriculumId               String                     @map("curriculum_id") @db.Uuid
  curriculumVersionId        String                     @map("curriculum_version_id") @db.Uuid
  academicSessionId          String                     @map("academic_session_id") @db.Uuid
  termId                     String                     @map("term_id") @db.Uuid
  academicClassId            String                     @map("academic_class_id") @db.Uuid
  schoolProgrammeComponentId String                     @map("school_programme_component_id") @db.Uuid
  teacherUserId              String?                    @map("teacher_user_id") @db.Uuid
  status                     CurriculumAssignmentStatus @default(PLANNED) @map("status")
  effectiveFrom              DateTime                   @map("effective_from") @db.Date
  effectiveTo                DateTime?                  @map("effective_to") @db.Date
  assignedById               String                     @map("assigned_by_id") @db.Uuid
  activatedById              String?                    @map("activated_by_id") @db.Uuid
  activatedAt                DateTime?                  @map("activated_at")
  completedAt                DateTime?                  @map("completed_at")
  archivedAt                 DateTime?                  @map("archived_at")
  createdAt                  DateTime                   @default(now()) @map("created_at")
  updatedAt                  DateTime                   @updatedAt @map("updated_at")

  school                 School                 @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  curriculum             Curriculum             @relation(fields: [curriculumId], references: [id], onDelete: Restrict)
  curriculumVersion      CurriculumVersion      @relation(fields: [curriculumVersionId, curriculumId], references: [id, curriculumId], onDelete: Restrict)
  academicSession        AcademicSession        @relation(fields: [academicSessionId, schoolId], references: [id, schoolId], onDelete: Restrict)
  term                   Term                   @relation(fields: [termId, schoolId], references: [id, schoolId], onDelete: Restrict)
  academicClass          AcademicClass          @relation(fields: [academicClassId, schoolId], references: [id, schoolId], onDelete: Restrict)
  schoolProgrammeComponent SchoolProgrammeComponent @relation("SchoolProgrammeComponentCurriculumAssignments", fields: [schoolProgrammeComponentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  teacherUser            User?                  @relation("CurriculumAssignmentTeacher", fields: [teacherUserId, schoolId], references: [id, schoolId], onDelete: Restrict)
  assignedByUser         User                   @relation("CurriculumAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)
  activatedByUser        User?                  @relation("CurriculumActivatedBy", fields: [activatedById], references: [id], onDelete: SetNull)

  @@index([schoolId, status, archivedAt])
  @@index([schoolId, academicSessionId, termId, academicClassId, schoolProgrammeComponentId, status])
  @@index([schoolId, teacherUserId, status])
  @@index([curriculumId, curriculumVersionId])
  @@map("curriculum_assignments")
}
