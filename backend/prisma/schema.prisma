generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  LOCKED
  ARCHIVED
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AcademicSessionStatus {
  PLANNED
  ACTIVE
  CLOSED
  ARCHIVED
}

enum TermStatus {
  PLANNED
  ACTIVE
  CLOSED
  ARCHIVED
}

enum AcademicClassStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum EnrolmentStatus {
  PENDING
  ACTIVE
  PROMOTED
  TRANSFERRED
  WITHDRAWN
  GRADUATED
  COMPLETED
  ARCHIVED
}

enum AcademicClassTeacherAssignmentType {
  CLASS_TEACHER
  ASSISTANT_TEACHER
  SUPERVISOR
}

enum SubjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum IntegrationDomainStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProgrammeComponentStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CurriculumSourceType {
  GOVERNMENT_CURRICULUM
  SCHOOL_SCHEME_OF_WORK
  INTERNATIONAL_FRAMEWORK
  TEXTBOOK
  TEACHER_MATERIAL
  WEBSITE
  INTERNAL_NOBLETECH_CONTENT
  UPLOADED_DOCUMENT
  OTHER
}

enum CurriculumSourceFormat {
  PDF
  DOCX
  XLSX
  CSV
  HTML
  URL
  TEXT
  IMAGE
  OTHER
}

enum ContentReviewStatus {
  DRAFT
  PENDING_REVIEW
  REVISION_REQUIRED
  APPROVED
  REJECTED
  ARCHIVED
}

enum MasterContentStatus {
  DRAFT
  UNDER_REVIEW
  REVISION_REQUIRED
  APPROVED
  ARCHIVED
}

enum CurriculumSourceContentType {
  SECTION
  UNIT
  TOPIC
  CONCEPT
  SKILL
  LEARNING_OUTCOME
  ACTIVITY
  PROJECT
  RESOURCE
  ASSESSMENT
  OTHER
}

enum CurriculumSourceProcessingStatus {
  DRAFT
  IN_PROGRESS
  PENDING_REVIEW
  REVISION_REQUIRED
  APPROVED
  REJECTED
  COMPLETED
  ARCHIVED
}

enum CurriculumSourceProcessingMethod {
  MANUAL
  OCR
  AI_ASSISTED
  IMPORTED
  HYBRID
}

enum CurriculumSourceSectionType {
  DOCUMENT_HEADING
  INTRODUCTION
  CLASS_LEVEL
  TERM
  SUBJECT
  UNIT
  TOPIC
  CONCEPT
  SKILL
  LEARNING_OUTCOME
  ACTIVITY
  PROJECT
  RESOURCE
  ASSESSMENT
  NOTE
  OTHER
}

enum CurriculumSourceSectionReviewStatus {
  DRAFT
  PENDING_REVIEW
  REVISION_REQUIRED
  APPROVED
  REJECTED
  ARCHIVED
}

enum CurriculumSourceFileStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum CurriculumSourceFileUploadStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum CurriculumSourceFileScanStatus {
  PENDING
  NOT_CONFIGURED
  CLEAN
  REJECTED
  FAILED
}

enum CurriculumChecksumAlgorithm {
  SHA256
}

enum CurriculumSourceFileCategory {
  SOURCE_DOCUMENT
  SUPPLEMENTARY_IMAGE
  SUPPLEMENTARY_DATA
  OTHER
}

enum CurriculumStorageProvider {
  LOCAL
  AZURE_BLOB
  AWS_S3
  GCP_STORAGE
}

enum MasterActivityType {
  DISCUSSION
  EXPERIMENT
  CREATIVE_TASK
  CODING_TASK
  ROBOTICS_TASK
  ENGINEERING_CHALLENGE
  RESEARCH_TASK
  OTHER
}

enum MasterProjectImplementationType {
  PHYSICAL_ROBOTICS
  SIMULATION_ONLY
  LOW_RESOURCE
  NO_LAPTOP
  INDIVIDUAL
  GROUP
  OTHER
}

enum MasterResourceType {
  SOFTWARE
  WEBSITE
  HARDWARE
  KIT
  DOCUMENT
  VIDEO
  AUDIO
  IMAGE
  OTHER
}

enum MasterAssessmentType {
  QUIZ
  PRACTICAL
  PROJECT
  ORAL
  WRITTEN
  PERFORMANCE
  OTHER
}

model School {
  id         String       @id @default(uuid()) @map("school_id") @db.Uuid
  code       String       @unique @map("school_code") @db.Citext
  name       String       @unique @map("school_name") @db.Citext
  status     SchoolStatus @default(ACTIVE) @map("status")
  email      String?      @map("email") @db.Citext
  phone      String?      @map("phone_number") @db.VarChar(30)
  address    String?      @map("address") @db.Text
  website    String?      @map("website") @db.VarChar(200)
  logoUrl    String?      @map("school_logo") @db.Text
  archivedAt DateTime?    @map("archived_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  users             User[]                           @relation("SchoolUsers")
  roles             Role[]                           @relation("SchoolRoles")
  students          Student[]                        @relation("SchoolStudents")
  guardians         Guardian[]                       @relation("SchoolGuardians")
  userRoles         UserRole[]                       @relation("SchoolUserRoles")
  studentGuardians  StudentGuardian[]                @relation("SchoolStudentGuardians")
  auditLogs         AuditLog[]                       @relation("SchoolAuditLogs")
  academicSessions  AcademicSession[]                @relation("SchoolAcademicSessions")
  terms             Term[]                           @relation("SchoolTerms")
  academicClasses   AcademicClass[]                  @relation("SchoolAcademicClasses")
  studentEnrolments StudentEnrolment[]               @relation("SchoolStudentEnrolments")
  classAssignments  AcademicClassTeacherAssignment[] @relation("SchoolAcademicClassAssignments")
  schoolSubjects    SchoolSubject[]                  @relation("SchoolSubjects")
  schoolComponents  SchoolProgrammeComponent[]       @relation("SchoolProgrammeComponents")
  termComponents    TermProgrammeComponent[]         @relation("SchoolTermProgrammeComponents")
  classComponents   ClassProgrammeComponent[]        @relation("SchoolClassProgrammeComponents")
  componentSettings ProgrammeComponentSetting[]      @relation("SchoolProgrammeComponentSettingSchool")
  curricula         Curriculum[]
  curriculumConcepts CurriculumConcept[]
  curriculumAssignments CurriculumAssignment[]
  curriculumSourceProcessingSessions CurriculumSourceProcessingSession[] @relation("CurriculumSourceProcessingSchool")

  @@index([status])
  @@map("schools")
}

model User {
  id                 String     @id @default(uuid()) @map("user_id") @db.Uuid
  schoolId           String?    @map("school_id") @db.Uuid
  firstName          String     @map("first_name") @db.VarChar(100)
  lastName           String     @map("last_name") @db.VarChar(100)
  email              String?    @unique @map("email") @db.Citext
  username           String     @unique @map("username") @db.Citext
  phoneNumber        String?    @map("phone_number") @db.VarChar(50)
  passwordHash       String     @map("password_hash") @db.Text
  status             UserStatus @default(INVITED) @map("status")
  mustChangePassword Boolean    @default(true) @map("must_change_password")
  lastLoginAt        DateTime?  @map("last_login_at")
  failedLoginCount   Int        @default(0) @map("failed_login_count")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  school                   School?                               @relation("SchoolUsers", fields: [schoolId], references: [id], onDelete: Restrict)
  studentProfile           Student?                              @relation("StudentUser")
  guardianProfile          Guardian?                             @relation("GuardianUser")
  roleAssignments          UserRole[]                            @relation("UserRoleUser")
  permissionGrants         RolePermission[]                      @relation("RolePermissionGrantedBy")
  auditActorLogs           AuditLog[]                            @relation("AuditActor")
  roleAssignmentsGiven     UserRole[]                            @relation("UserRoleAssignedBy")
  createdAcademicSessions  AcademicSession[]                     @relation("AcademicSessionCreatedBy")
  createdStudentEnrolments StudentEnrolment[]                    @relation("StudentEnrolmentCreatedBy")
  updatedStudentEnrolments StudentEnrolment[]                    @relation("StudentEnrolmentUpdatedBy")
  teachingAssignments      AcademicClassTeacherAssignment[]      @relation("AcademicClassTeacher")
  teachingAssignmentsGiven AcademicClassTeacherAssignment[]      @relation("AcademicClassTeacherAssignedBy")
  createdSubjects          Subject[]                             @relation("SubjectCreatedBy")
  createdSchoolSubjects    SchoolSubject[]                       @relation("SchoolSubjectCreatedBy")
  createdDomains           IntegrationDomain[]                   @relation("IntegrationDomainCreatedBy")
  createdDomainLinks       SubjectIntegrationDomain[]            @relation("SubjectIntegrationDomainCreatedBy")
  createdComponents        ProgrammeComponent[]                  @relation("ProgrammeComponentCreatedBy")
  updatedComponents        ProgrammeComponent[]                  @relation("ProgrammeComponentUpdatedBy")
  createdComponentSubjects ProgrammeComponentSubject[]           @relation("ProgrammeComponentSubjectCreatedBy")
  createdComponentDomains  ProgrammeComponentIntegrationDomain[] @relation("ProgrammeComponentDomainCreatedBy")
  createdSchoolComponents  SchoolProgrammeComponent[]            @relation("SchoolProgrammeComponentCreatedBy")
  updatedSchoolComponents  SchoolProgrammeComponent[]            @relation("SchoolProgrammeComponentUpdatedBy")
  createdTermComponents    TermProgrammeComponent[]              @relation("TermProgrammeComponentCreatedBy")
  createdClassComponents   ClassProgrammeComponent[]             @relation("ClassProgrammeComponentCreatedBy")
  createdComponentSettings ProgrammeComponentSetting[]           @relation("ProgrammeComponentSettingCreatedBy")
  updatedComponentSettings ProgrammeComponentSetting[]           @relation("ProgrammeComponentSettingUpdatedBy")
  changedComponentStatuses ProgrammeComponentStatusHistory[]     @relation("ProgrammeComponentStatusChangedBy")
  createdCurricula         Curriculum[]                          @relation("CurriculumCreatedBy")
  submittedCurricula       Curriculum[]                          @relation("CurriculumSubmittedBy")
  approvedCurricula        Curriculum[]                          @relation("CurriculumApprovedBy")
  publishedCurricula       Curriculum[]                          @relation("CurriculumPublishedBy")
  archivedCurricula        Curriculum[]                          @relation("CurriculumArchivedBy")
  createdCurriculumUnits   CurriculumUnit[]                      @relation("CurriculumUnitCreatedBy")
  updatedCurriculumUnits   CurriculumUnit[]                      @relation("CurriculumUnitUpdatedBy")
  createdCurriculumTopics  CurriculumTopic[]                     @relation("CurriculumTopicCreatedBy")
  updatedCurriculumTopics  CurriculumTopic[]                     @relation("CurriculumTopicUpdatedBy")
  createdCurriculumConcepts CurriculumConcept[]                  @relation("CurriculumConceptCreatedBy")
  createdCurriculumTopicConcepts CurriculumTopicConcept[]        @relation("CurriculumTopicConceptCreatedBy")
  createdCurriculumProjects CurriculumProject[]                  @relation("CurriculumProjectCreatedBy")
  updatedCurriculumProjects CurriculumProject[]                  @relation("CurriculumProjectUpdatedBy")
  createdCurriculumProjectImplementations CurriculumProjectImplementation[] @relation("CurriculumProjectImplementationCreatedBy")
  updatedCurriculumProjectImplementations CurriculumProjectImplementation[] @relation("CurriculumProjectImplementationUpdatedBy")
  createdCurriculumLearningOutcomes CurriculumLearningOutcome[]  @relation("CurriculumLearningOutcomeCreatedBy")
  updatedCurriculumLearningOutcomes CurriculumLearningOutcome[]  @relation("CurriculumLearningOutcomeUpdatedBy")
  createdCurriculumResources CurriculumResource[]                @relation("CurriculumResourceCreatedBy")
  updatedCurriculumResources CurriculumResource[]                @relation("CurriculumResourceUpdatedBy")
  createdCurriculumVersions CurriculumVersion[]                  @relation("CurriculumVersionCreatedBy")
  approvedCurriculumVersions CurriculumVersion[]                 @relation("CurriculumVersionApprovedBy")
  publishedCurriculumVersions CurriculumVersion[]                @relation("CurriculumVersionPublishedBy")
  curriculumReviewActionsAsActor CurriculumReviewAction[]        @relation("CurriculumReviewActor")
  curriculumReviewActionsAsReviewer CurriculumReviewAction[]     @relation("CurriculumAssignedReviewer")
  curriculumStatusHistoryChanges CurriculumStatusHistory[]       @relation("CurriculumStatusChangedBy")
  curriculumAssignmentsAsTeacher CurriculumAssignment[]          @relation("CurriculumAssignmentTeacher")
  curriculumAssignmentsGiven CurriculumAssignment[]              @relation("CurriculumAssignedBy")
  curriculumAssignmentsActivated CurriculumAssignment[]          @relation("CurriculumActivatedBy")
  startedCurriculumSourceProcessingSessions CurriculumSourceProcessingSession[] @relation("CurriculumSourceProcessingStartedBy")
  assignedCurriculumSourceProcessingReviews CurriculumSourceProcessingSession[] @relation("CurriculumSourceProcessingAssignedReviewer")
  createdCurriculumSourceSections CurriculumSourceSection[]      @relation("CurriculumSourceSectionCreatedBy")
  updatedCurriculumSourceSections CurriculumSourceSection[]      @relation("CurriculumSourceSectionUpdatedBy")
  createdCurriculumSourceContents CurriculumSourceContent[]      @relation("CurriculumSourceContentCreatedBy")

  @@unique([id, schoolId])
  @@index([schoolId, status])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @map("role_id") @db.Uuid
  schoolId    String?  @map("school_id") @db.Uuid
  name        String   @map("role_name") @db.VarChar(100)
  code        String   @map("role_code") @db.Citext
  description String?  @map("description") @db.Text
  isSystem    Boolean  @default(false) @map("is_system_role")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  school          School?          @relation("SchoolRoles", fields: [schoolId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]       @relation("UserRoleRole")
  rolePermissions RolePermission[] @relation("RolePermissionRole")

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([isActive])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @map("permission_id") @db.Uuid
  code        String   @unique @map("permission_code") @db.Citext
  name        String   @map("permission_name") @db.VarChar(150)
  resource    String   @map("resource") @db.VarChar(100)
  action      String   @map("action") @db.VarChar(100)
  description String?  @map("description") @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[] @relation("RolePermissionPermission")

  @@index([resource, action])
  @@index([isActive])
  @@map("permissions")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedAt    DateTime @default(now()) @map("granted_at")
  grantedById  String?  @map("granted_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role          Role       @relation("RolePermissionRole", fields: [roleId], references: [id], onDelete: Restrict)
  permission    Permission @relation("RolePermissionPermission", fields: [permissionId], references: [id], onDelete: Restrict)
  grantedByUser User?      @relation("RolePermissionGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@id([roleId, permissionId])
  @@index([grantedById, createdAt])
  @@map("role_permissions")
}

model UserRole {
  id           String    @id @default(uuid()) @map("user_role_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  schoolId     String?   @map("school_id") @db.Uuid
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  assignedById String?   @map("assigned_by_id") @db.Uuid
  expiresAt    DateTime? @map("expires_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user           User    @relation("UserRoleUser", fields: [userId], references: [id], onDelete: Restrict)
  role           Role    @relation("UserRoleRole", fields: [roleId], references: [id], onDelete: Restrict)
  school         School? @relation("SchoolUserRoles", fields: [schoolId], references: [id], onDelete: Restrict)
  assignedByUser User?   @relation("UserRoleAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([userId, roleId, schoolId, isActive])
  @@index([schoolId, isActive])
  @@index([assignedById, createdAt])
  @@map("user_roles")
}

model Student {
  id                 String        @id @default(uuid()) @map("student_id") @db.Uuid
  schoolId           String        @map("school_id") @db.Uuid
  userId             String?       @unique @map("user_id") @db.Uuid
  studentNumber      String        @map("student_number") @db.VarChar(100)
  admissionNumber    String?       @map("admission_number") @db.VarChar(100)
  firstName          String        @map("first_name") @db.VarChar(100)
  middleName         String?       @map("middle_name") @db.VarChar(100)
  lastName           String        @map("last_name") @db.VarChar(100)
  gender             Gender?       @map("gender")
  dateOfBirth        DateTime?     @map("date_of_birth") @db.Date
  contactEmail       String?       @map("email") @db.Citext
  phoneNumber        String?       @map("phone_number") @db.VarChar(50)
  residentialAddress String?       @map("residential_address") @db.Text
  status             StudentStatus @default(ACTIVE) @map("status")
  enrolmentDate      DateTime?     @map("enrolment_date") @db.Date
  archivedAt         DateTime?     @map("archived_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  school     School             @relation("SchoolStudents", fields: [schoolId], references: [id], onDelete: Restrict)
  user       User?              @relation("StudentUser", fields: [userId], references: [id], onDelete: SetNull)
  guardians  StudentGuardian[]  @relation("StudentGuardians")
  enrolments StudentEnrolment[] @relation("StudentEnrolments")

  @@unique([schoolId, admissionNumber])
  @@unique([schoolId, studentNumber])
  @@unique([id, schoolId])
  @@index([schoolId, status])
  @@index([schoolId, admissionNumber])
  @@map("students")
}

model Guardian {
  id             String   @id @default(uuid()) @map("guardian_id") @db.Uuid
  schoolId       String   @map("school_id") @db.Uuid
  userId         String?  @unique @map("user_id") @db.Uuid
  firstName      String   @map("first_name") @db.VarChar(100)
  middleName     String?  @map("middle_name") @db.VarChar(100)
  lastName       String   @map("last_name") @db.VarChar(100)
  email          String?  @map("email") @db.Citext
  phone          String?  @map("phone") @db.VarChar(50)
  alternatePhone String?  @map("alternate_phone") @db.VarChar(50)
  address        String?  @map("address") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  school   School            @relation("SchoolGuardians", fields: [schoolId], references: [id], onDelete: Restrict)
  user     User?             @relation("GuardianUser", fields: [userId], references: [id], onDelete: SetNull)
  students StudentGuardian[] @relation("GuardianStudents")

  @@index([schoolId])
  @@map("guardians")
}

model StudentGuardian {
  studentId               String   @map("student_id") @db.Uuid
  guardianId              String   @map("guardian_id") @db.Uuid
  schoolId                String   @map("school_id") @db.Uuid
  relationshipType        String   @map("relationship_type") @db.VarChar(100)
  isPrimary               Boolean  @default(false) @map("is_primary")
  canReceiveReports       Boolean  @default(true) @map("can_receive_reports")
  canReceiveNotifications Boolean  @default(true) @map("can_receive_notifications")
  canCollectStudent       Boolean  @default(false) @map("can_collect_student")
  hasPortalAccess         Boolean  @default(false) @map("has_portal_access")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  student  Student  @relation("StudentGuardians", fields: [studentId], references: [id], onDelete: Restrict)
  guardian Guardian @relation("GuardianStudents", fields: [guardianId], references: [id], onDelete: Restrict)
  school   School   @relation("SchoolStudentGuardians", fields: [schoolId], references: [id], onDelete: Restrict)

  @@id([studentId, guardianId])
  @@index([schoolId])
  @@map("student_guardians")
}

model AuditLog {
  id          String   @id @default(uuid()) @map("audit_log_id") @db.Uuid
  schoolId    String?  @map("school_id") @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String   @map("action") @db.VarChar(100)
  entityType  String   @map("entity_type") @db.VarChar(100)
  entityId    String   @map("entity_id") @db.VarChar(100)
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  reason      String?  @map("reason") @db.Text
  ipAddress   String?  @map("ip_address") @db.VarChar(100)
  userAgent   String?  @map("user_agent") @db.Text
  requestId   String?  @map("request_id") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")

  school    School? @relation("SchoolAuditLogs", fields: [schoolId], references: [id], onDelete: SetNull)
  actorUser User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([schoolId, createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([requestId])
  @@map("audit_logs")
}

model AcademicSession {
  id          String                @id @default(uuid()) @map("academic_session_id") @db.Uuid
  schoolId    String                @map("school_id") @db.Uuid
  name        String                @map("session_name") @db.VarChar(100)
  code        String                @map("session_code") @db.VarChar(50)
  startDate   DateTime              @map("start_date") @db.Date
  endDate     DateTime              @map("end_date") @db.Date
  status      AcademicSessionStatus @default(PLANNED) @map("status")
  isCurrent   Boolean               @default(false) @map("is_current")
  archivedAt  DateTime?             @map("archived_at")
  createdById String?               @map("created_by_id") @db.Uuid
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  school            School                           @relation("SchoolAcademicSessions", fields: [schoolId], references: [id], onDelete: Restrict)
  createdByUser     User?                            @relation("AcademicSessionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  terms             Term[]                           @relation("AcademicSessionTerms")
  studentEnrolments StudentEnrolment[]               @relation("AcademicSessionEnrolments")
  classAssignments  AcademicClassTeacherAssignment[] @relation("AcademicSessionClassAssignments")
  classComponents   ClassProgrammeComponent[]        @relation("AcademicSessionClassComponents")
  curriculumAssignments CurriculumAssignment[]

  @@unique([schoolId, name])
  @@unique([schoolId, code])
  @@unique([id, schoolId])
  @@index([schoolId, status])
  @@index([schoolId, isCurrent])
  @@map("academic_sessions")
}

model Term {
  id                String     @id @default(uuid()) @map("term_id") @db.Uuid
  schoolId          String     @map("school_id") @db.Uuid
  academicSessionId String     @map("academic_session_id") @db.Uuid
  name              String     @map("term_name") @db.VarChar(100)
  code              String     @map("term_code") @db.VarChar(50)
  sequenceOrder     Int        @map("sequence_order")
  startDate         DateTime   @map("start_date") @db.Date
  endDate           DateTime   @map("end_date") @db.Date
  status            TermStatus @default(PLANNED) @map("status")
  isCurrent         Boolean    @default(false) @map("is_current")
  archivedAt        DateTime?  @map("archived_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  school            School                           @relation("SchoolTerms", fields: [schoolId], references: [id], onDelete: Restrict)
  academicSession   AcademicSession                  @relation("AcademicSessionTerms", fields: [academicSessionId, schoolId], references: [id, schoolId], onDelete: Restrict)
  studentEnrolments StudentEnrolment[]               @relation("TermEnrolments")
  classAssignments  AcademicClassTeacherAssignment[] @relation("TermClassAssignments")
  termComponents    TermProgrammeComponent[]         @relation("TermProgrammeComponents")
  classComponents   ClassProgrammeComponent[]        @relation("TermClassProgrammeComponents")
  curriculumAssignments CurriculumAssignment[]

  @@unique([academicSessionId, name])
  @@unique([academicSessionId, code])
  @@unique([academicSessionId, sequenceOrder])
  @@unique([id, schoolId])
  @@index([schoolId, status])
  @@index([academicSessionId, sequenceOrder])
  @@index([schoolId, isCurrent])
  @@map("terms")
}

model AcademicClass {
  id             String              @id @default(uuid()) @map("academic_class_id") @db.Uuid
  schoolId       String              @map("school_id") @db.Uuid
  name           String              @map("class_name") @db.VarChar(100)
  code           String              @map("class_code") @db.VarChar(50)
  displayName    String?             @map("display_name") @db.VarChar(120)
  levelOrder     Int                 @map("level_order")
  educationLevel String?             @map("education_level") @db.VarChar(100)
  minimumAge     Int?                @map("minimum_age")
  maximumAge     Int?                @map("maximum_age")
  status         AcademicClassStatus @default(ACTIVE) @map("status")
  archivedAt     DateTime?           @map("archived_at")
  createdAt      DateTime            @default(now()) @map("created_at")
