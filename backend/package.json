{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:validate": "tsx src/scripts/prisma-validate.ts",
    "prisma:generate": "tsx src/scripts/prisma-generate.ts",
    "prisma:migrate:deploy": "tsx src/scripts/prisma-migrate-deploy.ts",
    "prisma:migrate:status": "tsx src/scripts/prisma-migrate-status.ts",
    "prisma:migration:checksum:audit": "tsx src/scripts/prisma-migration-checksum-audit.ts",
    "db:health": "tsx src/scripts/db-health.ts",
    "phase2l:db:verify": "tsx src/scripts/phase2l-source-file-db-verify.ts",
    "phase2l:constraints": "tsx src/scripts/phase2l-source-file-constraints-check.ts",
    "validate:phase2l": "tsx src/scripts/run-phase2l-validation.ts",
    "phase2m:db:verify": "tsx src/scripts/phase2m-source-processing-db-verify.ts",
    "phase2m:constraints": "tsx src/scripts/phase2m-source-processing-constraints-check.ts",
    "phase2m:rbac:audit": "tsx src/scripts/phase2m-rbac-audit.ts",
    "phase2m:rbac:apply": "tsx src/scripts/phase2m-rbac-audit.ts --apply",
    "phase2m:rbac:bootstrap": "tsx src/scripts/phase2m-rbac-bootstrap.ts --bootstrap-school-if-empty",
    "phase2m:rbac:verify": "tsx src/scripts/phase2m-rbac-verify.ts",
    "validate:phase2m": "tsx src/scripts/run-phase2m-validation.ts",
    "phase2n:db:verify": "tsx src/scripts/phase2n-master-content-promotion-db-verify.ts",
    "phase2n:constraints": "tsx src/scripts/phase2n-master-content-promotion-constraints-check.ts",
    "phase2n:rbac:audit": "tsx src/scripts/phase2n-rbac-audit.ts",
    "phase2n:rbac:apply": "tsx src/scripts/phase2n-rbac-audit.ts --apply",
    "phase2n:rbac:verify": "tsx src/scripts/phase2n-rbac-verify.ts",
    "validate:phase2n": "tsx src/scripts/run-phase2n-validation.ts",
    "phase2g:constraints": "tsx src/scripts/phase2g-curriculum-constraints-check.ts",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/multer": "^2.2.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "supertest": "^7.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
