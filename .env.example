###############################################################################
# NOBLETECH EDUCATION MANAGEMENT PLATFORM (NEMP)
# Environment Configuration Template
#
# Copy this file to ".env" and replace all placeholder values.
# Never commit your ".env" file to Git.
###############################################################################

###############################################################################
# APPLICATION INFORMATION
###############################################################################

APP_NAME="Nobletech Education Management Platform (NEMP)"
APP_SHORT_NAME=NEMP
APP_VERSION=1.0.0
API_VERSION=v1

APP_ENV=development
NODE_ENV=development

APP_DEBUG=true

APP_HOST=localhost
APP_PORT=5000

APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

DEFAULT_TIMEZONE=Africa/Lagos
DEFAULT_COUNTRY=Nigeria
DEFAULT_LANGUAGE=en

###############################################################################
# DATABASE CONFIGURATION (POSTGRESQL)
###############################################################################

DB_CONNECTION=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nemp_db
DB_SCHEMA=public
DB_USERNAME=postgres
DB_PASSWORD=your_database_password

DATABASE_URL="postgresql://postgres:your_database_password@localhost:5432/nemp_db?schema=public"

###############################################################################
# PRISMA
###############################################################################

PRISMA_LOG_LEVEL=query

###############################################################################
# JWT AUTHENTICATION
###############################################################################

JWT_SECRET=replace_with_a_very_long_secure_random_secret
JWT_EXPIRES_IN=1d

JWT_REFRESH_SECRET=replace_with_another_secure_random_secret
JWT_REFRESH_EXPIRES_IN=30d

JWT_ISSUER=NEMP
JWT_AUDIENCE=NEMP_USERS

###############################################################################
# PASSWORD SECURITY
###############################################################################

BCRYPT_SALT_ROUNDS=12

###############################################################################
# SESSION
###############################################################################

SESSION_SECRET=replace_with_secure_session_secret

###############################################################################
# CORS
###############################################################################

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

###############################################################################
# RATE LIMITING
###############################################################################

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

###############################################################################
# SECURITY
###############################################################################

TRUST_PROXY=false

ENABLE_HELMET=true

ENABLE_COMPRESSION=true

ENABLE_REQUEST_LOGGING=true

###############################################################################
# EMAIL (SMTP)
###############################################################################

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false

SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_email_password

SMTP_FROM_NAME="Nobletech Academy"
SMTP_FROM_EMAIL=noreply@example.com

###############################################################################
# SMS
###############################################################################

SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=Nobletech

###############################################################################
# AZURE BLOB STORAGE
###############################################################################

AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=nemp-storage

###############################################################################
# AMAZON S3 (OPTIONAL)
###############################################################################

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET=

###############################################################################
# GOOGLE SERVICES
###############################################################################

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

###############################################################################
# MICROSOFT SERVICES
###############################################################################

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

###############################################################################
# OPENAI / AI
###############################################################################

AI_PROVIDER=openai

OPENAI_API_KEY=

AI_MODEL=gpt-5.5

AI_MAX_TOKENS=4096

AI_TEMPERATURE=0.3

###############################################################################
# FILE STORAGE
###############################################################################

MAX_FILE_UPLOAD_SIZE=52428800
MAX_IMAGE_UPLOAD_SIZE=5242880

ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp

ALLOWED_DOCUMENT_TYPES=pdf,doc,docx,xls,xlsx,ppt,pptx,csv,txt

###############################################################################
# PDF ENGINE
###############################################################################

PDF_ENGINE=react-pdf

###############################################################################
# REDIS (FUTURE)
###############################################################################

REDIS_ENABLED=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

###############################################################################
# QUEUE (FUTURE)
###############################################################################

QUEUE_PROVIDER=memory

###############################################################################
# LOGGING
###############################################################################

LOG_LEVEL=info

LOG_FORMAT=combined

###############################################################################
# CACHE
###############################################################################

CACHE_PROVIDER=memory

###############################################################################
# APPLICATION FEATURES
###############################################################################

ENABLE_AUTHENTICATION=true
ENABLE_RBAC=true

ENABLE_CBT=true
ENABLE_REPORTS=true
ENABLE_PORTFOLIO=true
ENABLE_CERTIFICATES=true
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_AI=true

###############################################################################
# DEFAULT ADMIN ACCOUNT
# (Used only during first system installation)
###############################################################################

DEFAULT_ADMIN_NAME="System Administrator"

DEFAULT_ADMIN_EMAIL=admin@example.com

DEFAULT_ADMIN_PASSWORD=ChangeMeImmediately123!

###############################################################################
# SYSTEM DEFAULTS
###############################################################################

DEFAULT_SCHOOL_CODE=DEMO

DEFAULT_ACADEMIC_SESSION=2026/2027

DEFAULT_TERM=First Term

###############################################################################
# BACKUP
###############################################################################

BACKUP_ENABLED=true

BACKUP_RETENTION_DAYS=30

###############################################################################
# MONITORING
###############################################################################

ENABLE_HEALTH_CHECK=true

ENABLE_METRICS=true

###############################################################################
# DEVELOPMENT
###############################################################################

AUTO_CREATE_DATABASE=false

AUTO_RUN_MIGRATIONS=false

AUTO_RUN_SEED=false

###############################################################################
# TESTING
###############################################################################

TEST_DATABASE_URL="postgresql://postgres:password@localhost:5432/nemp_test?schema=public"

###############################################################################
# END OF FILE
###############################################################################