model CurriculumSourceMasterContentLink {
  id                            String                       @id @default(uuid()) @map("curriculum_source_master_content_link_id") @db.Uuid
  curriculumSourceId            String                       @map("curriculum_source_id") @db.Uuid
  masterCurriculumUnitId        String?                      @map("master_curriculum_unit_id") @db.Uuid
  masterTopicId                 String?                      @map("master_topic_id") @db.Uuid
  masterConceptId               String?                      @map("master_concept_id") @db.Uuid
  masterSkillId                 String?                      @map("master_skill_id") @db.Uuid
  masterLearningOutcomeId       String?                      @map("master_learning_outcome_id") @db.Uuid
  masterActivityId              String?                      @map("master_activity_id") @db.Uuid
  masterProjectId               String?                      @map("master_project_id") @db.Uuid
  masterProjectImplementationId String?                      @map("master_project_implementation_id") @db.Uuid
  masterResourceId              String?                      @map("master_resource_id") @db.Uuid
  masterAssessmentTemplateId    String?                      @map("master_assessment_template_id") @db.Uuid
  masterRubricId                String?                      @map("master_rubric_id") @db.Uuid
  sourceVersionLabel            String?                      @map("source_version_label") @db.VarChar(50)
  sourcePage                    String?                      @map("source_page") @db.VarChar(50)
  sourceSection                 String?                      @map("source_section") @db.VarChar(150)
  extractionNote                String?                      @map("extraction_note")
  adaptationNote                String?                      @map("adaptation_note")
  attribution                   String?                      @map("attribution")
  usageRestriction              String?                      @map("usage_restriction") @db.VarChar(150)
  reviewStatus                  ContentReviewStatus          @default(DRAFT) @map("review_status")
  createdById                   String                       @map("created_by_id") @db.Uuid
  createdAt                     DateTime                     @default(now()) @map("created_at")
  updatedAt                     DateTime                     @updatedAt @map("updated_at")
  users                         User                         @relation(fields: [createdById], references: [id])
  curriculumSource              CurriculumSource             @relation("CurriculumSourceMasterContentLinks", fields: [curriculumSourceId], references: [id])
  masterActivity                MasterActivity?              @relation("MasterActivitySourceLinks", fields: [masterActivityId], references: [id], onDelete: Restrict)
  masterAssessmentTemplate      MasterAssessmentTemplate?    @relation("MasterAssessmentTemplateSourceLinks", fields: [masterAssessmentTemplateId], references: [id], onDelete: Restrict)
  masterConcept                 MasterConcept?               @relation("MasterConceptSourceLinks", fields: [masterConceptId], references: [id], onDelete: Restrict)
  masterCurriculumUnit          MasterCurriculumUnit?        @relation("MasterCurriculumUnitSourceLinks", fields: [masterCurriculumUnitId], references: [id], onDelete: Restrict)
  masterLearningOutcome         MasterLearningOutcome?       @relation("MasterLearningOutcomeSourceLinks", fields: [masterLearningOutcomeId], references: [id], onDelete: Restrict)
  masterProject                 MasterProject?               @relation("MasterProjectSourceLinks", fields: [masterProjectId], references: [id], onDelete: Restrict)
  masterProjectImplementation   MasterProjectImplementation? @relation("MasterProjectImplementationSourceLinks", fields: [masterProjectImplementationId], references: [id], onDelete: Restrict)
  masterResource                MasterResource?              @relation("MasterResourceSourceLinks", fields: [masterResourceId], references: [id], onDelete: Restrict)
  masterRubric                  MasterRubric?                @relation("MasterRubricSourceLinks", fields: [masterRubricId], references: [id], onDelete: Restrict)
  masterSkill                   MasterSkill?                 @relation("MasterSkillSourceLinks", fields: [masterSkillId], references: [id], onDelete: Restrict)
  masterTopic                   MasterTopic?                 @relation("MasterTopicSourceLinks", fields: [masterTopicId], references: [id], onDelete: Restrict)

  @@index([curriculumSourceId, reviewStatus])
  @@index([reviewStatus, createdAt])
  @@map("curriculum_source_master_content_links")
}

