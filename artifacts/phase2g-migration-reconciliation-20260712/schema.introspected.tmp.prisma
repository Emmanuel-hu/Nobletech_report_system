generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id                             String                           @id @default(uuid()) @map("school_id") @db.Uuid
  code                           String                           @unique @map("school_code") @db.Citext
  name                           String                           @unique @map("school_name") @db.Citext
  status                         SchoolStatus                     @default(ACTIVE) @map("status")
  email                          String?                          @map("email") @db.Citext
  phone                          String?                          @map("phone_number") @db.VarChar(30)
  address                        String?                          @map("address")
  website                        String?                          @map("website") @db.VarChar(200)
  logoUrl                        String?                          @map("school_logo")
  archivedAt                     DateTime?                        @map("archived_at")
  createdAt                      DateTime                         @default(now()) @map("created_at")
  updatedAt                      DateTime                         @updatedAt @map("updated_at")
  classAssignments               AcademicClassTeacherAssignment[] @relation("SchoolAcademicClassAssignments")
  academicClasses                AcademicClass[]                  @relation("SchoolAcademicClasses")
  academicSessions               AcademicSession[]                @relation("SchoolAcademicSessions")
  auditLogs                      AuditLog[]                       @relation("SchoolAuditLogs")
  classComponents                ClassProgrammeComponent[]        @relation("SchoolClassProgrammeComponents")
  curriculum_sources             CurriculumSource[]
  guardians                      Guardian[]                       @relation("SchoolGuardians")
  master_activities              MasterActivity[]
  master_assessment_templates    MasterAssessmentTemplate[]
  master_concepts                MasterConcept[]
  master_curriculum_units        MasterCurriculumUnit[]
  master_learning_outcomes       MasterLearningOutcome[]
  master_project_implementations MasterProjectImplementation[]
  master_projects                MasterProject[]
  master_resources               MasterResource[]
  master_rubrics                 MasterRubric[]
  master_skills                  MasterSkill[]
  master_topics                  MasterTopic[]
  componentSettings              ProgrammeComponentSetting[]      @relation("SchoolProgrammeComponentSettingSchool")
  roles                          Role[]                           @relation("SchoolRoles")
  schoolComponents               SchoolProgrammeComponent[]       @relation("SchoolProgrammeComponents")
  schoolSubjects                 SchoolSubject[]                  @relation("SchoolSubjects")
  studentEnrolments              StudentEnrolment[]               @relation("SchoolStudentEnrolments")
  studentGuardians               StudentGuardian[]                @relation("SchoolStudentGuardians")
  students                       Student[]                        @relation("SchoolStudents")
  termComponents                 TermProgrammeComponent[]         @relation("SchoolTermProgrammeComponents")
  terms                          Term[]                           @relation("SchoolTerms")
  userRoles                      UserRole[]                       @relation("SchoolUserRoles")
  users                          User[]                           @relation("SchoolUsers")

  @@index([status])
  @@map("schools")
}

model User {
  id                                                                    String                                    @id @default(uuid()) @map("user_id") @db.Uuid
  schoolId                                                              String?                                   @map("school_id") @db.Uuid
  firstName                                                             String                                    @map("first_name") @db.VarChar(100)
  lastName                                                              String                                    @map("last_name") @db.VarChar(100)
  email                                                                 String?                                   @unique @map("email") @db.Citext
  username                                                              String                                    @unique @map("username") @db.Citext
  phoneNumber                                                           String?                                   @map("phone_number") @db.VarChar(50)
  passwordHash                                                          String                                    @map("password_hash")
  status                                                                UserStatus                                @default(INVITED) @map("status")
  mustChangePassword                                                    Boolean                                   @default(true) @map("must_change_password")
  lastLoginAt                                                           DateTime?                                 @map("last_login_at")
  failedLoginCount                                                      Int                                       @default(0) @map("failed_login_count")
  createdAt                                                             DateTime                                  @default(now()) @map("created_at")
  updatedAt                                                             DateTime                                  @updatedAt @map("updated_at")
  teachingAssignmentsGiven                                              AcademicClassTeacherAssignment[]          @relation("AcademicClassTeacherAssignedBy")
  teachingAssignments                                                   AcademicClassTeacherAssignment[]          @relation("AcademicClassTeacher")
  createdAcademicSessions                                               AcademicSession[]                         @relation("AcademicSessionCreatedBy")
  auditActorLogs                                                        AuditLog[]                                @relation("AuditActor")
  createdClassComponents                                                ClassProgrammeComponent[]                 @relation("ClassProgrammeComponentCreatedBy")
  curriculum_source_contents                                            CurriculumSourceContent[]
  curriculum_source_master_content_links                                CurriculumSourceMasterContentLink[]
  curriculum_sources_curriculum_sources_approved_by_idTousers           CurriculumSource[]                        @relation("curriculum_sources_approved_by_idTousers")
  curriculum_sources_curriculum_sources_reviewed_by_idTousers           CurriculumSource[]                        @relation("curriculum_sources_reviewed_by_idTousers")
  curriculum_sources_curriculum_sources_uploaded_by_idTousers           CurriculumSource[]                        @relation("curriculum_sources_uploaded_by_idTousers")
  guardianProfile                                                       Guardian?                                 @relation("GuardianUser")
  createdDomains                                                        IntegrationDomain[]                       @relation("IntegrationDomainCreatedBy")
  master_activities                                                     MasterActivity[]
  master_activity_resources                                             MasterActivityResource[]
  master_assessment_template_learning_outcomes                          MasterAssessmentTemplateLearningOutcome[]
  master_assessment_templates                                           MasterAssessmentTemplate[]
  master_concepts                                                       MasterConcept[]
  master_curriculum_unit_integration_domains                            MasterCurriculumUnitIntegrationDomain[]
  master_curriculum_unit_programme_components                           MasterCurriculumUnitProgrammeComponent[]
  master_curriculum_unit_subjects                                       MasterCurriculumUnitSubject[]
  master_curriculum_units_master_curriculum_units_approved_by_idTousers MasterCurriculumUnit[]                    @relation("master_curriculum_units_approved_by_idTousers")
  master_curriculum_units_master_curriculum_units_created_by_idTousers  MasterCurriculumUnit[]                    @relation("master_curriculum_units_created_by_idTousers")
  master_curriculum_units_master_curriculum_units_reviewed_by_idTousers MasterCurriculumUnit[]                    @relation("master_curriculum_units_reviewed_by_idTousers")
  master_learning_outcomes                                              MasterLearningOutcome[]
  master_project_implementations                                        MasterProjectImplementation[]
  master_project_learning_outcomes                                      MasterProjectLearningOutcome[]
  master_project_resources                                              MasterProjectResource[]
  master_project_skills                                                 MasterProjectSkill[]
  master_projects                                                       MasterProject[]
  master_resources                                                      MasterResource[]
  master_rubrics                                                        MasterRubric[]
  master_skills                                                         MasterSkill[]
  master_topic_activities                                               MasterTopicActivity[]
  master_topic_concepts                                                 MasterTopicConcept[]
  master_topic_integration_domains                                      MasterTopicIntegrationDomain[]
  master_topic_learning_outcomes                                        MasterTopicLearningOutcome[]
  master_topic_projects                                                 MasterTopicProject[]
  master_topic_skills                                                   MasterTopicSkill[]
  master_topic_subjects                                                 MasterTopicSubject[]
  master_topics                                                         MasterTopic[]
  createdComponentDomains                                               ProgrammeComponentIntegrationDomain[]     @relation("ProgrammeComponentDomainCreatedBy")
  createdComponentSettings                                              ProgrammeComponentSetting[]               @relation("ProgrammeComponentSettingCreatedBy")
  updatedComponentSettings                                              ProgrammeComponentSetting[]               @relation("ProgrammeComponentSettingUpdatedBy")
  changedComponentStatuses                                              ProgrammeComponentStatusHistory[]         @relation("ProgrammeComponentStatusChangedBy")
  createdComponentSubjects                                              ProgrammeComponentSubject[]               @relation("ProgrammeComponentSubjectCreatedBy")
  createdComponents                                                     ProgrammeComponent[]                      @relation("ProgrammeComponentCreatedBy")
  updatedComponents                                                     ProgrammeComponent[]                      @relation("ProgrammeComponentUpdatedBy")
  permissionGrants                                                      RolePermission[]                          @relation("RolePermissionGrantedBy")
  createdSchoolComponents                                               SchoolProgrammeComponent[]                @relation("SchoolProgrammeComponentCreatedBy")
  updatedSchoolComponents                                               SchoolProgrammeComponent[]                @relation("SchoolProgrammeComponentUpdatedBy")
  createdSchoolSubjects                                                 SchoolSubject[]                           @relation("SchoolSubjectCreatedBy")
  createdStudentEnrolments                                              StudentEnrolment[]                        @relation("StudentEnrolmentCreatedBy")
  updatedStudentEnrolments                                              StudentEnrolment[]                        @relation("StudentEnrolmentUpdatedBy")
  studentProfile                                                        Student?                                  @relation("StudentUser")
  createdDomainLinks                                                    SubjectIntegrationDomain[]                @relation("SubjectIntegrationDomainCreatedBy")
  createdSubjects                                                       Subject[]                                 @relation("SubjectCreatedBy")
  createdTermComponents                                                 TermProgrammeComponent[]                  @relation("TermProgrammeComponentCreatedBy")
  roleAssignmentsGiven                                                  UserRole[]                                @relation("UserRoleAssignedBy")
  roleAssignments                                                       UserRole[]                                @relation("UserRoleUser")
  school                                                                School?                                   @relation("SchoolUsers", fields: [schoolId], references: [id], onDelete: Restrict)

  @@unique([id, schoolId])
  @@index([schoolId, status])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @map("role_id") @db.Uuid
  schoolId        String?          @map("school_id") @db.Uuid
  name            String           @map("role_name") @db.VarChar(100)
  code            String           @map("role_code") @db.Citext
  description     String?          @map("description")
  isSystem        Boolean          @default(false) @map("is_system_role")
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[] @relation("RolePermissionRole")
  school          School?          @relation("SchoolRoles", fields: [schoolId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]       @relation("UserRoleRole")

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([isActive])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @map("permission_id") @db.Uuid
  code            String           @unique @map("permission_code") @db.Citext
  name            String           @map("permission_name") @db.VarChar(150)
  resource        String           @map("resource") @db.VarChar(100)
  action          String           @map("action") @db.VarChar(100)
  description     String?          @map("description")
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[] @relation("RolePermissionPermission")

  @@index([resource, action])
  @@index([isActive])
  @@map("permissions")
}

model RolePermission {
  roleId        String     @map("role_id") @db.Uuid
  permissionId  String     @map("permission_id") @db.Uuid
  grantedAt     DateTime   @default(now()) @map("granted_at")
  grantedById   String?    @map("granted_by_id") @db.Uuid
  createdAt     DateTime   @default(now()) @map("created_at")
  grantedByUser User?      @relation("RolePermissionGrantedBy", fields: [grantedById], references: [id])
  permission    Permission @relation("RolePermissionPermission", fields: [permissionId], references: [id])
  role          Role       @relation("RolePermissionRole", fields: [roleId], references: [id])

  @@id([roleId, permissionId])
  @@index([grantedById, createdAt])
  @@map("role_permissions")
}

model UserRole {
  id             String    @id @default(uuid()) @map("user_role_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  roleId         String    @map("role_id") @db.Uuid
  schoolId       String?   @map("school_id") @db.Uuid
  assignedAt     DateTime  @default(now()) @map("assigned_at")
  assignedById   String?   @map("assigned_by_id") @db.Uuid
  expiresAt      DateTime? @map("expires_at")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  assignedByUser User?     @relation("UserRoleAssignedBy", fields: [assignedById], references: [id])
  role           Role      @relation("UserRoleRole", fields: [roleId], references: [id])
  school         School?   @relation("SchoolUserRoles", fields: [schoolId], references: [id], onDelete: Restrict)
  user           User      @relation("UserRoleUser", fields: [userId], references: [id])

  @@index([userId, roleId, schoolId, isActive])
  @@index([schoolId, isActive])
  @@index([assignedById, createdAt])
  @@map("user_roles")
}

model Student {
  id                 String             @id @default(uuid()) @map("student_id") @db.Uuid
  schoolId           String             @map("school_id") @db.Uuid
  userId             String?            @unique @map("user_id") @db.Uuid
  studentNumber      String             @map("student_number") @db.VarChar(100)
  admissionNumber    String?            @map("admission_number") @db.VarChar(100)
  firstName          String             @map("first_name") @db.VarChar(100)
  middleName         String?            @map("middle_name") @db.VarChar(100)
  lastName           String             @map("last_name") @db.VarChar(100)
  gender             Gender?            @map("gender")
  dateOfBirth        DateTime?          @map("date_of_birth") @db.Date
  contactEmail       String?            @map("email") @db.Citext
  phoneNumber        String?            @map("phone_number") @db.VarChar(50)
  residentialAddress String?            @map("residential_address")
  status             StudentStatus      @default(ACTIVE) @map("status")
  enrolmentDate      DateTime?          @map("enrolment_date") @db.Date
  archivedAt         DateTime?          @map("archived_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  enrolments         StudentEnrolment[] @relation("StudentEnrolments")
  guardians          StudentGuardian[]  @relation("StudentGuardians")
  school             School             @relation("SchoolStudents", fields: [schoolId], references: [id])
  user               User?              @relation("StudentUser", fields: [userId], references: [id])

  @@unique([schoolId, admissionNumber])
  @@unique([schoolId, studentNumber])
  @@unique([id, schoolId])
  @@index([schoolId, status])
  @@index([schoolId, admissionNumber])
  @@map("students")
}

model Guardian {
  id             String            @id @default(uuid()) @map("guardian_id") @db.Uuid
  schoolId       String            @map("school_id") @db.Uuid
  userId         String?           @unique @map("user_id") @db.Uuid
  firstName      String            @map("first_name") @db.VarChar(100)
  middleName     String?           @map("middle_name") @db.VarChar(100)
  lastName       String            @map("last_name") @db.VarChar(100)
  email          String?           @map("email") @db.Citext
  phone          String?           @map("phone") @db.VarChar(50)
  alternatePhone String?           @map("alternate_phone") @db.VarChar(50)
  address        String?           @map("address")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  school         School            @relation("SchoolGuardians", fields: [schoolId], references: [id])
  user           User?             @relation("GuardianUser", fields: [userId], references: [id])
  students       StudentGuardian[] @relation("GuardianStudents")

  @@index([schoolId])
  @@map("guardians")
}

model StudentGuardian {
  studentId               String   @map("student_id") @db.Uuid
  guardianId              String   @map("guardian_id") @db.Uuid
  schoolId                String   @map("school_id") @db.Uuid
  relationshipType        String   @map("relationship_type") @db.VarChar(100)
  isPrimary               Boolean  @default(false) @map("is_primary")
  canReceiveReports       Boolean  @default(true) @map("can_receive_reports")
  canReceiveNotifications Boolean  @default(true) @map("can_receive_notifications")
  canCollectStudent       Boolean  @default(false) @map("can_collect_student")
  hasPortalAccess         Boolean  @default(false) @map("has_portal_access")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  guardian                Guardian @relation("GuardianStudents", fields: [guardianId], references: [id])
  school                  School   @relation("SchoolStudentGuardians", fields: [schoolId], references: [id])
  student                 Student  @relation("StudentGuardians", fields: [studentId], references: [id])

  @@id([studentId, guardianId])
  @@index([schoolId])
  @@map("student_guardians")
}

model AuditLog {
  id          String   @id @default(uuid()) @map("audit_log_id") @db.Uuid
  schoolId    String?  @map("school_id") @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String   @map("action") @db.VarChar(100)
  entityType  String   @map("entity_type") @db.VarChar(100)
  entityId    String   @map("entity_id") @db.VarChar(100)
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  reason      String?  @map("reason")
  ipAddress   String?  @map("ip_address") @db.VarChar(100)
  userAgent   String?  @map("user_agent")
  requestId   String?  @map("request_id") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  school      School?  @relation("SchoolAuditLogs", fields: [schoolId], references: [id])

  @@index([schoolId, createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([requestId])
  @@map("audit_logs")
}

model AcademicSession {
  id                String                           @id @default(uuid()) @map("academic_session_id") @db.Uuid
  schoolId          String                           @map("school_id") @db.Uuid
  name              String                           @map("session_name") @db.VarChar(100)
  code              String                           @map("session_code") @db.VarChar(50)
  startDate         DateTime                         @map("start_date") @db.Date
  endDate           DateTime                         @map("end_date") @db.Date
  status            AcademicSessionStatus            @default(PLANNED) @map("status")
  isCurrent         Boolean                          @default(false) @map("is_current")
  archivedAt        DateTime?                        @map("archived_at")
  createdById       String?                          @map("created_by_id") @db.Uuid
  createdAt         DateTime                         @default(now()) @map("created_at")
  updatedAt         DateTime                         @updatedAt @map("updated_at")
  classAssignments  AcademicClassTeacherAssignment[] @relation("AcademicSessionClassAssignments")
  createdByUser     User?                            @relation("AcademicSessionCreatedBy", fields: [createdById], references: [id])
  school            School                           @relation("SchoolAcademicSessions", fields: [schoolId], references: [id])
  classComponents   ClassProgrammeComponent[]        @relation("AcademicSessionClassComponents")
  studentEnrolments StudentEnrolment[]               @relation("AcademicSessionEnrolments")
  terms             Term[]                           @relation("AcademicSessionTerms")

  @@unique([schoolId, name])
  @@unique([schoolId, code])
  @@unique([id, schoolId])
  @@index([schoolId, status])
  @@index([schoolId, isCurrent])
  @@map("academic_sessions")
}

model Term {
  id                String                           @id @default(uuid()) @map("term_id") @db.Uuid
  schoolId          String                           @map("school_id") @db.Uuid
  academicSessionId String                           @map("academic_session_id") @db.Uuid
  name              String                           @map("term_name") @db.VarChar(100)
  code              String                           @map("term_code") @db.VarChar(50)
  sequenceOrder     Int                              @map("sequence_order")
  startDate         DateTime                         @map("start_date") @db.Date
  endDate           DateTime                         @map("end_date") @db.Date
  status            TermStatus                       @default(PLANNED) @map("status")
  isCurrent         Boolean                          @default(false) @map("is_current")
  archivedAt        DateTime?                        @map("archived_at")
  createdAt         DateTime                         @default(now()) @map("created_at")
  updatedAt         DateTime                         @updatedAt @map("updated_at")
  classAssignments  AcademicClassTeacherAssignment[] @relation("TermClassAssignments")
  classComponents   ClassProgrammeComponent[]        @relation("TermClassProgrammeComponents")
  studentEnrolments StudentEnrolment[]               @relation("TermEnrolments")
  termComponents    TermProgrammeComponent[]         @relation("TermProgrammeComponents")
  academicSession   AcademicSession                  @relation("AcademicSessionTerms", fields: [academicSessionId, schoolId], references: [id, schoolId])
  school            School                           @relation("SchoolTerms", fields: [schoolId], references: [id])

  @@unique([academicSessionId, name])
  @@unique([academicSessionId, code])
  @@unique([academicSessionId, sequenceOrder])
  @@unique([id, schoolId])
  @@index([schoolId, status])
  @@index([academicSessionId, sequenceOrder])
  @@index([schoolId, isCurrent])
  @@map("terms")
}

model AcademicClass {
  id                String                           @id @default(uuid()) @map("academic_class_id") @db.Uuid
  schoolId          String                           @map("school_id") @db.Uuid
  name              String                           @map("class_name") @db.VarChar(100)
  code              String                           @map("class_code") @db.VarChar(50)
  displayName       String?                          @map("display_name") @db.VarChar(120)
  levelOrder        Int                              @map("level_order")
  educationLevel    String?                          @map("education_level") @db.VarChar(100)
  minimumAge        Int?                             @map("minimum_age")
  maximumAge        Int?                             @map("maximum_age")
  status            AcademicClassStatus              @default(ACTIVE) @map("status")
  archivedAt        DateTime?                        @map("archived_at")
  createdAt         DateTime                         @default(now()) @map("created_at")
  updatedAt         DateTime                         @updatedAt @map("updated_at")
  classAssignments  AcademicClassTeacherAssignment[] @relation("AcademicClassTeacherAssignments")
  school            School                           @relation("SchoolAcademicClasses", fields: [schoolId], references: [id])
  classComponents   ClassProgrammeComponent[]        @relation("AcademicClassProgrammeComponents")
  studentEnrolments StudentEnrolment[]               @relation("AcademicClassEnrolments")

  @@unique([schoolId, name])
  @@unique([schoolId, code])
  @@unique([id, schoolId])
  @@index([schoolId, status])
  @@index([schoolId, levelOrder])
  @@map("academic_classes")
}

model StudentEnrolment {
  id                      String             @id @default(uuid()) @map("student_enrolment_id") @db.Uuid
  schoolId                String             @map("school_id") @db.Uuid
  studentId               String             @map("student_id") @db.Uuid
  academicSessionId       String             @map("academic_session_id") @db.Uuid
  termId                  String?            @map("term_id") @db.Uuid
  academicClassId         String             @map("academic_class_id") @db.Uuid
  enrolmentStatus         EnrolmentStatus    @default(PENDING) @map("enrolment_status")
  enrolmentDate           DateTime           @map("enrolment_date") @db.Date
  completionDate          DateTime?          @map("completion_date") @db.Date
  withdrawalDate          DateTime?          @map("withdrawal_date") @db.Date
  transferDate            DateTime?          @map("transfer_date") @db.Date
  previousEnrolmentId     String?            @map("previous_enrolment_id") @db.Uuid
  promotedFromEnrolmentId String?            @map("promoted_from_enrolment_id") @db.Uuid
  notes                   String?            @map("notes")
  createdById             String?            @map("created_by_id") @db.Uuid
  updatedById             String?            @map("updated_by_id") @db.Uuid
  archivedAt              DateTime?          @map("archived_at")
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  academicClass           AcademicClass      @relation("AcademicClassEnrolments", fields: [academicClassId, schoolId], references: [id, schoolId])
  academicSession         AcademicSession    @relation("AcademicSessionEnrolments", fields: [academicSessionId, schoolId], references: [id, schoolId])
  createdByUser           User?              @relation("StudentEnrolmentCreatedBy", fields: [createdById], references: [id])
  previousEnrolment       StudentEnrolment?  @relation("StudentEnrolmentPrevious", fields: [previousEnrolmentId], references: [id])
  nextEnrolments          StudentEnrolment[] @relation("StudentEnrolmentPrevious")
  promotedFromEnrolment   StudentEnrolment?  @relation("StudentEnrolmentPromotedFrom", fields: [promotedFromEnrolmentId], references: [id])
  promotedToEnrolments    StudentEnrolment[] @relation("StudentEnrolmentPromotedFrom")
  school                  School             @relation("SchoolStudentEnrolments", fields: [schoolId], references: [id])
  student                 Student            @relation("StudentEnrolments", fields: [studentId, schoolId], references: [id, schoolId])
  term                    Term?              @relation("TermEnrolments", fields: [termId, schoolId], references: [id, schoolId])
  updatedByUser           User?              @relation("StudentEnrolmentUpdatedBy", fields: [updatedById], references: [id])

  @@index([schoolId, enrolmentStatus])
  @@index([studentId, academicSessionId])
  @@index([academicClassId, academicSessionId])
  @@index([schoolId, academicSessionId, academicClassId])
  @@index([termId])
  @@map("student_enrolments")
}

model AcademicClassTeacherAssignment {
  id                String                             @id @default(uuid()) @map("academic_class_teacher_assignment_id") @db.Uuid
  schoolId          String                             @map("school_id") @db.Uuid
  userId            String                             @map("user_id") @db.Uuid
  academicSessionId String                             @map("academic_session_id") @db.Uuid
  termId            String?                            @map("term_id") @db.Uuid
  academicClassId   String                             @map("academic_class_id") @db.Uuid
  assignmentType    AcademicClassTeacherAssignmentType @map("assignment_type")
  isPrimary         Boolean                            @default(false) @map("is_primary")
  isActive          Boolean                            @default(true) @map("is_active")
  startDate         DateTime                           @map("start_date") @db.Date
  endDate           DateTime?                          @map("end_date") @db.Date
  assignedById      String?                            @map("assigned_by_id") @db.Uuid
  createdAt         DateTime                           @default(now()) @map("created_at")
  updatedAt         DateTime                           @updatedAt @map("updated_at")
  academicClass     AcademicClass                      @relation("AcademicClassTeacherAssignments", fields: [academicClassId, schoolId], references: [id, schoolId])
